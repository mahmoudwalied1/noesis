NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noesis
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20
DEFAULT_ADMIN_EMAIL=admin@noesis.local
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
